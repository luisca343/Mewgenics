# ── Raw game files (huge, not redistributable) ───────────────────────
# Original game archive (~4.7 GB) and its extracted contents (~4.8 GB)
resources.gpak
/dump/

# ── Vendored third-party binaries (downloaded, ~250 MB) ───────────────
# ffdec (SWF decompiler) and bundled JRE, plus their archives
/tools/vendor/

# ── Generated wiki assets (sprites/icons, ~433 MB) ────────────────────
# Regenerable from the dump via the export tools
/wiki_data/assets/

# ── Generated preview page ────────────────────────────────────────────
# Rebuilt by tools/generate_preview.py
/preview.html

